---
/**
 * Zero-JS card surface for Astro pages — the same CARD_SURFACE the Solid <Card>
 * wears. Surface-only by default (`padding="none"`); `slots` for the
 * CardHeader/Content/Footer rhythm, `md`/`sm` for a bare tile.
 */
import {
	CARD_INTERACTIVE,
	CARD_PADDING,
	type CardPadding,
	CARD_SURFACE,
	CARD_SURFACE_OPAQUE,
} from "../lib/card-classes";
import { cn } from "../lib/utils";

interface Props {
	as?: keyof HTMLElementTagNameMap;
	interactive?: boolean;
	/** Opaque solid surface (no backdrop blur). Use over busy/dark backgrounds or
	 *  in animated contexts where blur can't run. */
	opaque?: boolean;
	padding?: CardPadding;
	class?: string;
}

const {
	as: Tag = "div",
	interactive = false,
	opaque = false,
	padding = "none",
	class: className,
	...rest
} = Astro.props;

const classes = cn(
	opaque ? CARD_SURFACE_OPAQUE : CARD_SURFACE,
	"rounded-[var(--radius)]",
	CARD_PADDING[padding],
	interactive && CARD_INTERACTIVE,
	className,
);
---

<Tag data-slot="card" class={classes} {...rest}>
	<slot />
</Tag>
