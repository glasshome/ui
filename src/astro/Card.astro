---
import {
	CARD_INTERACTIVE,
	CARD_PADDING,
	CARD_SURFACE,
	CARD_SURFACE_OPAQUE,
	type CardPadding,
} from "../lib/card-classes";
import { cn } from "../lib/utils";

interface Props {
	as?: keyof HTMLElementTagNameMap;
	interactive?: boolean;
	opaque?: boolean;
	padding?: CardPadding;
	class?: string;
}

const {
	as: Tag = "div",
	interactive = false,
	opaque = false,
	padding = "none",
	class: className,
	...rest
} = Astro.props;

const classes = cn(
	opaque ? CARD_SURFACE_OPAQUE : CARD_SURFACE,
	"rounded-[var(--radius)]",
	CARD_PADDING[padding],
	interactive && CARD_INTERACTIVE,
	className,
);
---

<Tag data-slot="card" class={classes} {...rest}>
	<slot />
</Tag>
