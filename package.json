{
	"name": "@glasshome/ui",
	"version": "0.3.3",
	"description": "SolidJS component library for GlassHome, built on Kobalte",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"homepage": "https://github.com/glasshome/ui#readme",
	"bugs": {
		"url": "https://github.com/glasshome/ui/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=18"
	},
	"sideEffects": false,
	"keywords": [
		"solidjs",
		"components",
		"kobalte",
		"ui",
		"home-assistant",
		"smart-home",
		"tailwindcss",
		"glasshome"
	],
	"exports": {
		".": {
			"@glasshome/source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./solid": {
			"@glasshome/source": "./src/solid/index.ts",
			"types": "./dist/solid/index.d.ts",
			"import": "./dist/solid/index.js"
		},
		"./tokens": {
			"@glasshome/source": "./src/tokens/index.ts",
			"types": "./dist/tokens/index.d.ts",
			"import": "./dist/tokens/index.js"
		},
		"./styles": "./src/styles/globals.css",
		"./package.json": "./package.json",
		"./styles/theme": "./src/styles/theme.css"
	},
	"files": [
		"dist",
		"src/styles"
	],
	"scripts": {
		"build": "vite build && tsc",
		"check:tokens": "bun scripts/check-tokens.ts",
		"dev": "vite build --watch",
		"lint": "biome check ."
	},
	"peerDependencies": {
		"@glasshome/sync-layer": ">=0.1.0",
		"solid-js": "^1.9.9"
	},
	"dependencies": {
		"@iconify-icon/solid": "^3.0.3",
		"@kobalte/core": "^0.13.11",
		"clsx": "^2.1.1",
		"cva": "^1.0.0-beta.4",
		"embla-carousel": "^8.5.1",
		"lucide-solid": "^1.21.0",
		"solid-sonner": "^0.3.1",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.13",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@types/json-schema": "^7.0.15",
		"@types/node": "^25.2.2",
		"typescript": "^5",
		"vite": "^8.1.0",
		"vite-plugin-solid": "^2.11.12",
		"@biomejs/biome": "2.4.15"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/glasshome/ui.git"
	},
	"author": "GlassHome Labs",
	"license": "MIT"
}
