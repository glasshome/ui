{
	"name": "@glasshome/ui",
	"version": "1.0.1",
	"description": "SolidJS component library for GlassHome, built on Kobalte",
	"type": "module",
	"homepage": "https://github.com/glasshome/ui#readme",
	"bugs": {
		"url": "https://github.com/glasshome/ui/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20"
	},
	"sideEffects": [
		"**/*.css"
	],
	"keywords": [
		"solidjs",
		"components",
		"kobalte",
		"ui",
		"home-assistant",
		"smart-home",
		"tailwindcss",
		"glasshome"
	],
	"exports": {
		".": {
			"@glasshome/source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./solid": {
			"@glasshome/source": "./src/solid/index.ts",
			"types": "./dist/solid/index.d.ts",
			"import": "./dist/solid/index.js"
		},
		"./tokens": {
			"@glasshome/source": "./src/tokens/index.ts",
			"types": "./dist/tokens/index.d.ts",
			"import": "./dist/tokens/index.js"
		},
		"./astro/*": "./src/astro/*",
		"./styles": "./src/styles/globals.css",
		"./package.json": "./package.json",
		"./styles/theme": "./src/styles/theme.css",
		"./scripts/*": "./scripts/*"
	},
	"files": [
		"dist",
		"src/astro",
		"src/lib",
		"src/styles",
		"scripts"
	],
	"scripts": {
		"build": "vite build && tsc",
		"check:tokens": "bun scripts/check-tokens.ts",
		"check:types": "tsc --noEmit -p tsconfig.test.json",
		"check:publish": "publint && attw --pack . --profile esm-only --exclude-entrypoints ./styles ./styles/theme",
		"dev": "vite build --watch",
		"lint": "biome check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"dev:gallery": "vite --config vite.dev.config.ts"
	},
	"peerDependencies": {
		"astro": ">=4",
		"solid-js": "^1.9.9",
		"tailwindcss": "^4.1.13",
		"tw-animate-css": "^1.4.0"
	},
	"dependencies": {
		"@iconify-icon/solid": "^3.0.3",
		"@kobalte/core": "^0.13.11",
		"clsx": "^2.1.1",
		"cva": "^1.0.0-beta.4",
		"embla-carousel": "^8.5.1",
		"solid-sonner": "^0.3.1",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.5",
		"@biomejs/biome": "2.4.15",
		"@solidjs/testing-library": "^0.8.10",
		"@tailwindcss/vite": "^4.1.13",
		"@types/json-schema": "^7.0.15",
		"@types/node": "^25.2.2",
		"happy-dom": "^20.11.0",
		"publint": "^0.3.21",
		"tailwindcss": "^4.1.13",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vite": "^8.1.0",
		"vite-plugin-solid": "^2.11.12",
		"vitest": "^4.1.10"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/glasshome/ui.git"
	},
	"author": "GlassHome Labs",
	"license": "MIT",
	"peerDependenciesMeta": {
		"astro": {
			"optional": true
		}
	}
}
