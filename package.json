{
  "name": "@glasshome/ui",
  "version": "0.1.0",
  "description": "SolidJS component library for GlassHome, built on Kobalte",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@glasshome/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./solid": {
      "@glasshome/source": "./src/solid/index.ts",
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js"
    },
    "./solid/*": {
      "@glasshome/source": "./src/solid/*.tsx",
      "types": "./dist/solid/*.d.ts",
      "import": "./dist/solid/*.js"
    },
    "./styles": "./src/styles/globals.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "solid-js": "^1.9.9"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "clsx": "^2.1.1",
    "cva": "^1.0.0-beta.4",
    "embla-carousel": "^8.5.1",
    "lucide-solid": "^0.544.0",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/glasshome-labs/ui.git"
  },
  "author": "GlassHome Labs",
  "license": "MIT"
}
