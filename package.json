{
  "name": "@glasshome/ui",
  "version": "0.1.2",
  "description": "SolidJS component library for GlassHome, built on Kobalte",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/glasshome/ui#readme",
  "bugs": {
    "url": "https://github.com/glasshome/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "solidjs",
    "components",
    "kobalte",
    "ui",
    "home-assistant",
    "smart-home",
    "tailwindcss",
    "glasshome"
  ],
  "exports": {
    ".": {
      "@glasshome/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./solid": {
      "@glasshome/source": "./src/solid/index.ts",
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js"
    },
    "./styles": "./src/styles/globals.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "@glasshome/sync-layer": ">=0.1.0",
    "solid-js": "^1.9.9"
  },
  "dependencies": {
    "@iconify-icon/solid": "^3.0.3",
    "@kobalte/core": "^0.13.11",
    "clsx": "^2.1.1",
    "cva": "^1.0.0-beta.4",
    "embla-carousel": "^8.5.1",
    "lucide-solid": "^0.544.0",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.2.2",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/glasshome/ui.git"
  },
  "author": "GlassHome Labs",
  "license": "MIT"
}
